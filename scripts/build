#!/usr/bin/env bash

set -e

PACKAGE="${1:-all}"

echo ""
echo "=================================="
echo " TX Runtime Builder"
echo "=================================="
echo ""

echo "Building package: $PACKAGE"

case "$PACKAGE" in

all)
    echo "TX Runtime build placeholder"
    mkdir -p out
    echo "TX Runtime build completed." > out/build.txt
    ;;

busybox)
    echo "BusyBox build not implemented yet"
    ;;

bash)
    echo "GNU Bash build not implemented yet"
    ;;

curl)
    echo "Curl build not implemented yet"
    ;;

*)
    echo "Unknown package: $PACKAGE"
    exit 1
    ;;
esac
